+        result["message"] = f"Queue file not found: {queue_file}"
+        return result
+
+    content = queue_file.read_text()
+
+    # Parse existing counts from summary table
+    file_counts: dict[str, int] = {}
+    for line in content.splitlines():
+        for agent in AGENTS:
