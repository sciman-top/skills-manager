+class SessionVerdict(enum.Enum):
+    CONTINUE = "CONTINUE"
+    PAUSE = "PAUSE"
+    STOP = "STOP"
+
+
+@dataclass
+class LimitResult:
+    checkpoint_id: str
+    name: str
+    verdict: SessionVerdict
+    current_value: int
+    threshold: int
+    message: str
