{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "MAX_TEAMMATES": "10",
    "REVIEW_GATE_STRICT": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|MultiEdit|Glob|Grep|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-governor-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-logger.sh pre",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/plan-approval-gate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/config-protection-pretooluse.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-content-pretooluse.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/cross-review-gate.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-read-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-workflow-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-validate-commit.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|MultiEdit|Glob|Grep|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/error-loop-tracker.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cat | \"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/capture-corrections.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-phase-boundary.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Read|Write|Edit|MultiEdit|Glob|Grep|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-logger.sh post",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/context-budget-monitor.sh\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'SCRIPT=\"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/consume-signals.sh\"; [ -f \"$SCRIPT\" ] && bash \"$SCRIPT\" 2>/dev/null || true'",
            "timeout": 10,
            "statusMessage": "Capturing session signals"
          },
          {
            "type": "command",
            "command": "cat | bash \"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/emit-session-quality-signals.sh\" 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Emitting session quality signals"
          },
          {
            "type": "command",
            "command": "cat | bash \"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/skill-nudge-stop.sh\" 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Checking for skill creation opportunities"
          },
          {
            "type": "command",
            "command": "bash \"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/session-review.sh\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Extracting session review signals"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/skill-nudge-start.sh\" 2>/dev/null || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${WORKSPACE_HUB:-$(git rev-parse --show-superproject-working-tree 2>/dev/null | grep . || git rev-parse --show-toplevel)}/.claude/hooks/daily-learning-tip.sh\" 2>/dev/null || true",
            "timeout": 3,
            "statusMessage": "Daily learning tip"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-session-state.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "plansDirectory": ".planning",
  "showThinkingSummaries": true,
  "outputStyle": "Explanatory",
  "effortLevel": "high",
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".cache",
      ".venv",
      "__pycache__"
    ],
    "sparsePaths": []
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Engineering",
      "Analyzing",
      "Modeling",
      "Simulating",
      "Calibrating"
    ]
  },
  "spinnerTipsOverride": {
    "tips": [
      "Run /context to check your budget — /compact at 50%",
      "Run /simplify after changes to catch duplication",
      "Use /effort low for quick lookups, /effort high for planning",
      "Say 'use subagents' to offload heavy work from main context",
      "Run /diff to review your changes before committing",
      "Use /branch before a risky approach — explore freely",
      "Try /security-review before pushing a PR",
      "uv run scripts/productivity/daily-learning.py for today's tips"
    ],
    "excludeDefault": false
  },
  "deny": [
    "Bash(rm -rf /)",
    "Bash(rm -rf ~:*)",
    "Bash(rm -rf .:*)",
    "Bash(dd if=/dev/zero:*)",
    "Bash(mkfs:*)",
    "Bash(shred:*)",
    "Bash(sudo:*)",
    "Bash(su :*)",
    "Bash(pkexec:*)",
    "Bash(doas:*)",
    "Bash(chmod 777:*)",
    "Bash(eval:*)",
    "Bash(sh -c:*)",
    "Bash(bash -c:*)",
    "Bash(zsh -c:*)",
    "Bash(python -c:*)",
    "Bash(python3 -c:*)",
    "Bash(perl -e:*)",
    "Bash(ruby -e:*)",
    "Bash(node -e:*)",
    "Bash(curl * | bash:*)",
    "Bash(curl * | sh:*)",
    "Bash(wget * -O- | bash:*)",
    "Bash(wget * -O- | sh:*)",
    "Bash(| bash:*)",
    "Bash(| sh:*)",
    "Bash(nc:*)",
    "Bash(ncat:*)",
    "Bash(base64:*)",
    "Bash(xxd:*)",
    "Bash(git push --force:*)",
    "Bash(git push -f:*)",
    "Bash(git push --force-with-lease:*)",
    "Bash(git -c core.hooksPath:*)",
    "Bash(git -c core.hookspath:*)",
    "Bash(crontab:*)",
    "Bash(systemctl:*)"
  ]
}
