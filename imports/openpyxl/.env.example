# .env.example — Standardized environment variables for workspace-hub
# Issue: #1543
#
# Copy to .env and adjust paths for your machine.
# Scripts should source this file or use these env vars instead of hardcoded paths.
#
# Topology:
#   ace-linux-1 (dev-primary)  — main data server, /mnt/ace is local
#   ace-linux-2 (dev-secondary) — analysis workstation, mounts via NFS/SSHFS

# ── Repository root ─────────────────────────────────────────────────────────
# Prefer $(git rev-parse --show-toplevel) in scripts; this is the fallback.
WORKSPACE_HUB_ROOT=/mnt/local-analysis/workspace-hub

# ── Primary data drive (ace) ────────────────────────────────────────────────
# ace-linux-1: /mnt/ace  (local)
# ace-linux-2: /mnt/remote/ace-linux-1/ace  (NFS4)
ACE_DATA_ROOT=/mnt/remote/ace-linux-1/ace

# ── Document-intelligence summaries ─────────────────────────────────────────
# Relocated to ace drive per #1540; local copy kept as cache
SUMMARIES_DIR=${WORKSPACE_HUB_ROOT}/data/document-index/summaries
SUMMARIES_DIR_REMOTE=${ACE_DATA_ROOT}/data/document-index/summaries

# ── DDE drive (legacy documents, Orcaflex, literature) ──────────────────────
# ace-linux-1: /mnt/remote/ace-linux-2/dde  (SSHFS)
# ace-linux-2: /mnt/dde  (local)
DDE_ROOT=/mnt/dde

# ── Python virtual environments ─────────────────────────────────────────────
LOCAL_ANALYSIS_ROOT=/mnt/local-analysis
CAPYTAINE_ENV=${LOCAL_ANALYSIS_ROOT}/capytaine-env
MARKER_ENV=${LOCAL_ANALYSIS_ROOT}/marker-env
FLUIDS_ENV=${LOCAL_ANALYSIS_ROOT}/fluids-env
SECTIONPROPS_ENV=${LOCAL_ANALYSIS_ROOT}/sectionprops-env

# ── Remote mounts (cross-machine access) ────────────────────────────────────
# These are only valid when the corresponding SSHFS/NFS mounts are active.
REMOTE_LOCAL_ANALYSIS_ROOT=/mnt/remote/ace-linux-1/local-analysis

# ── Legacy paths (to be migrated) ──────────────────────────────────────────
# These appear in scripts/automation/ and scripts/coordination/git/.
# Replace with WORKSPACE_HUB_ROOT in new code.
# LEGACY: GITHUB_DIR=/mnt/github/github
# LEGACY: WORKSPACE_ROOT=/mnt/github/workspace-hub
