prefix_rule(pattern=["git", "add", "scripts/cron/skills-curation.sh", "scripts/coordination/productivity/crontab.example", "tests/cron/test_skills_curation.py"], decision="allow")
prefix_rule(pattern=["git", "rev-parse", "--short", "HEAD"], decision="allow")
prefix_rule(pattern=["git", "add", ".codex/agents/batch/config.toml", ".codex/agents/explorer/config.toml", ".codex/agents/worker/config.toml"], decision="allow")
prefix_rule(pattern=["git", "rev-list", "--left-right", "--count", "origin/main...HEAD"], decision="allow")
prefix_rule(pattern=["pkill", "-f", "git status -sb && git rev-list --left-right --count origin/main...HEAD"], decision="allow")
