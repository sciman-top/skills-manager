{
  "provider": "gemini",
  "model_ref": "config/agents/model-registry.yaml#gemini.default_model",
  "focus": "research",
  "strengths": "research, data analysis, summarization, content, documents",
  "skills_path": ".gemini/skills",
  "permissions": {
    "allow": [
      "Bash(gemini:*)",
      "Read(*)",
      "Write(*)"
    ]
  },
  "experimental": {
    "enableAgents": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .gemini/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .gemini/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .gemini/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .gemini/hooks/gsd-statusline.js"
  }
}
