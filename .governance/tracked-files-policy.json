{
  "schema_version": "v1",
  "owner": "repo-governance-hub",
  "description": "Tracked files policy for staging/push filtering. Block transient artifacts and local-only configs.",
  "enforcement": {
    "block_on_must_ignore": true,
    "block_on_review_required": false,
    "block_on_test_file_review_required": true
  },
  "test_file_suggestions": {
    "enabled": true,
    "detection_patterns": [
      "**/tests/**",
      "**/test/**",
      "**/__tests__/**",
      "**/*.test.*",
      "**/*.spec.*",
      "**/test*.ps1",
      "**/*test*.ps1"
    ],
    "suggest_ignore": [
      {
        "pattern": "**/tmp/**",
        "reason": "temporary test folder should stay local"
      },
      {
        "pattern": "**/temp/**",
        "reason": "temporary test folder should stay local"
      },
      {
        "pattern": "**/scratch/**",
        "reason": "scratch test folder should stay local"
      },
      {
        "pattern": "**/playground/**",
        "reason": "playground test folder should stay local"
      },
      {
        "pattern": "**/*.tmp.test.*",
        "reason": "tmp-marked test file should stay local"
      },
      {
        "pattern": "**/*.temp.test.*",
        "reason": "temp-marked test file should stay local"
      },
      {
        "pattern": "**/*.scratch.test.*",
        "reason": "scratch-marked test file should stay local"
      },
      {
        "pattern": "**/*manual*.test.*",
        "reason": "manual test probes should stay local unless explicitly approved"
      },
      {
        "pattern": "**/*debug*.test.*",
        "reason": "debug test probes should stay local unless explicitly approved"
      }
    ],
    "suggest_track": [
      {
        "pattern": "tests/**",
        "reason": "canonical persistent test directory"
      },
      {
        "pattern": "**/tests/**",
        "reason": "canonical persistent test directory"
      },
      {
        "pattern": "**/__tests__/**",
        "reason": "canonical persistent test directory"
      },
      {
        "pattern": "**/*.spec.*",
        "reason": "spec file is typically persistent"
      },
      {
        "pattern": "**/*.test.*",
        "reason": "test file is typically persistent unless tagged as temporary"
      }
    ],
    "suggest_review_required": [
      {
        "pattern": "**/scripts/**/test*.ps1",
        "reason": "script-based tests need explicit ownership judgement"
      }
    ]
  },
  "rules": {
    "must_ignore": [
      {
        "pattern": ".codex/**",
        "reason": "agent local runtime and logs"
      },
      {
        "pattern": ".claude/**",
        "reason": "agent local runtime and logs"
      },
      {
        "pattern": ".gemini/**",
        "reason": "agent local runtime and logs"
      },
      {
        "pattern": ".playwright-cli/**",
        "reason": "browser automation local state"
      },
      {
        "pattern": ".idea/**",
        "reason": "IDE local settings"
      },
      {
        "pattern": ".vscode/**",
        "reason": "IDE local settings"
      },
      {
        "pattern": "*.code-workspace",
        "reason": "IDE local workspace"
      },
      {
        "pattern": "*.suo",
        "reason": "IDE local state"
      },
      {
        "pattern": "*.user",
        "reason": "IDE local state"
      },
      {
        "pattern": "*.userosscache",
        "reason": "IDE local state"
      },
      {
        "pattern": "*.sln.docstates",
        "reason": "IDE local state"
      },
      {
        "pattern": "backups/**",
        "reason": "local rollback snapshots"
      },
      {
        "pattern": ".locks/**",
        "reason": "local lock files"
      },
      {
        "pattern": "docs/governance/metrics-auto.md",
        "reason": "auto-generated runtime metrics snapshot"
      },
      {
        "pattern": "docs/governance/alerts-latest.md",
        "reason": "auto-generated recurring review alert snapshot"
      },
      {
        "pattern": "docs/governance/reviews/**",
        "reason": "auto-generated monthly governance reviews"
      },
      {
        "pattern": "logs/**",
        "reason": "local logs"
      },
      {
        "pattern": "tmp/**",
        "reason": "temporary artifacts"
      },
      {
        "pattern": "temp/**",
        "reason": "temporary artifacts"
      },
      {
        "pattern": "cache/**",
        "reason": "temporary cache"
      },
      {
        "pattern": "*.bak",
        "reason": "backup artifact"
      },
      {
        "pattern": "*.cache",
        "reason": "cache artifact"
      },
      {
        "pattern": "*.diff",
        "reason": "debug artifact"
      },
      {
        "pattern": "*.err",
        "reason": "debug artifact"
      },
      {
        "pattern": "*.log",
        "reason": "log artifact"
      },
      {
        "pattern": "*.orig",
        "reason": "merge/debug artifact"
      },
      {
        "pattern": "*.out",
        "reason": "debug artifact"
      },
      {
        "pattern": "*.pid",
        "reason": "runtime artifact"
      },
      {
        "pattern": "*.rej",
        "reason": "patch reject artifact"
      },
      {
        "pattern": "*.stackdump",
        "reason": "crash artifact"
      },
      {
        "pattern": "*.temp",
        "reason": "temporary artifact"
      },
      {
        "pattern": "*.tmp",
        "reason": "temporary artifact"
      }
    ],
    "review_required": [
      {
        "pattern": ".governance/waivers/*.md",
        "reason": "waiver change requires owner confirmation and expiry review"
      },
      {
        "pattern": "docs/change-evidence/*.md",
        "reason": "evidence files should match actual command outputs and rollback"
      }
    ],
    "must_track": [
      {
        "pattern": ".gitignore",
        "reason": "ignore baseline is source of policy truth"
      },
      {
        "pattern": ".governance/tracked-files-policy.json",
        "reason": "tracked-files policy should be versioned"
      }
    ]
  }
}

