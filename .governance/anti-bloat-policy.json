{
  "schema_version": "1.0",
  "enabled": true,
  "enforce": {
    "block_on_violation": true,
    "require_merge_or_deprecation_plan_on_violation": false,
    "allow_with_active_plan": false,
    "plan_path": ".governance/complexity-budget-plan.json"
  },
  "scope": {
    "prefer_git_pending": true,
    "include_untracked": true,
    "scan_repo_when_no_pending": false,
    "max_repo_files": 200
  },
  "scan": {
    "include_extensions": [
      ".ps1",
      ".psm1",
      ".psd1",
      ".cs",
      ".py",
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".go",
      ".java",
      ".kt",
      ".rb",
      ".php",
      ".md"
    ],
    "exclude_paths": [
      ".git/",
      "node_modules/",
      "dist/",
      "build/",
      "bin/",
      "obj/",
      "backups/",
      ".venv/",
      "coverage/",
      "docs/",
      "tests/"
    ]
  },
  "limits": {
    "max_file_lines": 1000,
    "max_consecutive_non_empty_lines": 220,
    "max_estimated_tokens_per_file": 8000,
    "max_estimated_tokens_total_pending": 40000,
    "max_duplicate_line_occurrences": 32,
    "chars_per_token": 4
  },
  "mode_limits": {
    "lite": {
      "max_file_lines": 800,
      "max_consecutive_non_empty_lines": 180,
      "max_estimated_tokens_per_file": 6000,
      "max_estimated_tokens_total_pending": 25000,
      "max_duplicate_line_occurrences": 24
    },
    "standard": {
      "max_file_lines": 1000,
      "max_consecutive_non_empty_lines": 220,
      "max_estimated_tokens_per_file": 8000,
      "max_estimated_tokens_total_pending": 40000,
      "max_duplicate_line_occurrences": 32
    },
    "deep": {
      "max_file_lines": 1200,
      "max_consecutive_non_empty_lines": 260,
      "max_estimated_tokens_per_file": 12500,
      "max_estimated_tokens_total_pending": 70000,
      "max_duplicate_line_occurrences": 40
    }
  },
  "repo_overrides": [
    {
      "repoName": "ClassroomToolkit",
      "mode_limits": {
        "standard": {
          "max_estimated_tokens_per_file": 14000,
          "max_estimated_tokens_total_pending": 70000
        }
      }
    },
    {
      "repoName": "skills-manager",
      "mode_limits": {
        "standard": {
          "max_estimated_tokens_per_file": 20000,
          "max_estimated_tokens_total_pending": 90000
        }
      }
    },
    {
      "repoName": "repo-governance-hub",
      "enforce": {
        "require_merge_or_deprecation_plan_on_violation": true,
        "allow_with_active_plan": true,
        "plan_path": ".governance/complexity-budget-plan.json"
      },
      "mode_limits": {
        "deep": {
          "max_file_lines": 1250,
          "max_estimated_tokens_per_file": 14000
        }
      }
    }
  ]
}

