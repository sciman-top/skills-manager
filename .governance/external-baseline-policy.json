{
  "schema_version": "1.0",
  "enforcement": {
    "block_on_warn": true,
    "block_on_advisory": false
  },
  "checks": {
    "ssdf": {
      "enabled": true,
      "level": "required",
      "evidence_any_of": [
        "docs/governance/ssdf-mapping.md",
        ".governance/ssdf-mapping.md",
        "docs/governance/ssdf-checklist.md"
      ]
    },
    "slsa": {
      "enabled": true,
      "level": "required",
      "evidence_any_of": [
        ".github/workflows/slsa.yml",
        ".github/workflows/slsa-provenance.yml",
        "docs/governance/slsa-target-level.md"
      ]
    },
    "sbom": {
      "enabled": true,
      "level": "required",
      "evidence_any_of": [
        "scripts/quality/run-supply-chain-checks.ps1",
        ".github/workflows/sbom.yml",
        "docs/governance/sbom-policy.md"
      ]
    },
    "scorecard": {
      "enabled": true,
      "level": "required",
      "evidence_any_of": [
        ".github/workflows/scorecard.yml",
        "docs/governance/scorecard-policy.md"
      ]
    },
    "code_scanning": {
      "enabled": true,
      "level": "required",
      "evidence_any_of": [
        ".github/workflows/codeql.yml"
      ]
    },
    "dependency_review": {
      "enabled": true,
      "level": "required",
      "evidence_any_of": [
        ".github/workflows/dependency-review.yml"
      ]
    },
    "codeowners": {
      "enabled": true,
      "level": "required",
      "evidence_any_of": [
        ".github/CODEOWNERS"
      ]
    },
    "repository_rulesets": {
      "enabled": true,
      "level": "recommended",
      "evidence_any_of": [
        ".governance/repository-ruleset-policy.json",
        ".github/rulesets/default.json",
        ".governance/repository-ruleset-config.json",
        "docs/governance/repository-ruleset-policy.md"
      ]
    }
  }
}
