{
  "schema_version": "1.0",
  "enabled": true,
  "states": [
    "candidate",
    "approved",
    "active",
    "deprecated",
    "retired"
  ],
  "actions": {
    "create": {
      "require_user_ack": true,
      "require_trigger_eval_pass": true,
      "require_unique_family": true
    },
    "optimize": {
      "require_material_delta": true,
      "allow_without_user_ack": true
    },
    "merge": {
      "enabled": true,
      "similarity_threshold": 0.8
    },
    "retire": {
      "enabled": true,
      "inactive_days": 60,
      "min_invocations": 3
    }
  },
  "metrics": {
    "min_quality_delta_for_optimize": 0.0,
    "max_false_trigger_rate": 0.2,
    "min_validation_pass_rate": 0.7
  }
}
