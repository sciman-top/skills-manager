#!/usr/bin/env sh
set -eu

staged="$(git diff --cached --name-only --diff-filter=ACMR)"

block_pattern='^(\.txn/|build\.log$|\.build-cache\.json$)'
blocked="$(printf '%s\n' "$staged" | grep -E "$block_pattern" || true)"
if [ -n "$blocked" ]; then
  echo "[pre-commit] blocked: temporary artifacts are staged (.txn/, build.log, .build-cache.json)." >&2
  echo "[pre-commit] matched staged paths:" >&2
  printf '%s\n' "$blocked" >&2
  echo "[pre-commit] run the following to unstage:" >&2
  printf '%s\n' "$blocked" | sed 's#^#git restore --staged -- #' >&2
  exit 1
fi

# Reject commit when any submodule worktree is dirty.
if git submodule status --recursive 2>/dev/null | grep -E '[-]dirty' >/dev/null 2>&1; then
  echo "[pre-commit] blocked: dirty submodule detected (-dirty)." >&2
  echo "Please commit/clean submodule changes first." >&2
  exit 1
fi

exit 0
